{
  "entities": {
    "UserWorkspace": {
      "title": "User Workspace",
      "description": "A workspace mapping to a specific user for isolating their data.",
      "type": "object",
      "properties": {
        "ownerId": {
          "type": "string",
          "description": "User ID of the owner."
        },
        "settings": {
          "type": "object",
          "properties": {
            "currency": { "type": "string" },
            "defaultMargin": { "type": "number" },
            "lowStockLimit": { "type": "number" },
            "usdRate": { "type": "number" },
            "usdRateHistory": { "type": "array" }
          }
        },
        "createdAt": { "type": "number", "description": "Server timestamp of creation." },
        "updatedAt": { "type": "number", "description": "Server timestamp of last update." }
      },
      "required": ["ownerId", "settings", "createdAt", "updatedAt"]
    },
    "Product": {
      "title": "Product",
      "description": "A product for sale, raw material, or resale item.",
      "type": "object",
      "properties": {
        "workspaceId": { "type": "string" },
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "type": { "type": "string", "enum": ["resale", "raw", "processed"] },
        "unit": { "type": "string" },
        "currency": { "type": "string" },
        "supplier": { "type": "string" },
        "category":{ "type": "string" },
        "stock": { "type": "number" },
        "purchaseCost": { "type": "number" },
        "extraCost": { "type": "number" },
        "wasteRate": { "type": "number" },
        "targetMargin": { "type": "number" },
        "salePrice": { "type": "number" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["workspaceId", "name", "type", "unit", "createdAt", "updatedAt"]
    },
    "Purchase": {
      "title": "Purchase",
      "description": "A record of purchasing inventory.",
      "type": "object",
      "properties": {
        "workspaceId": { "type": "string" },
        "productId": { "type": "string" },
        "date": { "type": "string" },
        "supplier": { "type": "string" },
        "quantity": { "type": "number" },
        "unitCost": { "type": "number" },
        "extraCost": { "type": "number" },
        "note": { "type": "string" },
        "currency": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["workspaceId", "productId", "date", "quantity", "unitCost", "createdAt"]
    },
    "Recipe": {
      "title": "Recipe",
      "description": "A formula to process raw materials into a processed product.",
      "type": "object",
      "properties": {
        "workspaceId": { "type": "string" },
        "productId": { "type": "string" },
        "components": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "quantity": { "type": "number" }
            }
          }
        },
        "yield": { "type": "number" },
        "processCost": { "type": "number" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["workspaceId", "productId", "components", "yield", "processCost", "createdAt", "updatedAt"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "A vendor providing raw materials or resale items.",
      "type": "object",
      "properties": {
        "workspaceId": { "type": "string" },
        "name": { "type": "string" },
        "contact": { "type": "string" },
        "paymentTerms": { "type": "string" },
        "currency": { "type": "string" },
        "deliveryTime": { "type": "number" },
        "location": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["workspaceId", "name", "createdAt", "updatedAt"]
    },
    "Reminder": {
      "title": "Reminder",
      "description": "A reminder or to-do item for the business.",
      "type": "object",
      "properties": {
        "workspaceId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["workspaceId", "title", "dueDate", "completed", "createdAt", "updatedAt"]
    },
    "User": {
      "title": "User",
      "description": "A user of the system.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["superadmin", "admin", "seller", "stock", "viewer"] },
        "workspaceId": { "type": "string", "description": "Null if superadmin" },
        "createdBy": { "type": "string" },
        "isActive": { "type": "boolean" },
        "lastLogin": { "type": "number" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["email", "displayName", "role", "isActive", "createdAt", "updatedAt"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Log of user actions.",
      "type": "object",
      "properties": {
        "workspaceId": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "action": { "type": "string" },
        "entityType": { "type": "string" },
        "entityId": { "type": "string" },
        "description": { "type": "string" },
        "timestamp": { "type": "number" },
        "ip": { "type": "string" }
      },
      "required": ["workspaceId", "userId", "userEmail", "action", "entityType", "description", "timestamp"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Sales records or invoices",
      "type": "object",
      "properties": {
        "workspaceId": { "type": "string" },
        "clientName": { "type": "string" },
        "date": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "totalAmount": { "type": "number" },
        "currency": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["workspaceId", "date", "items", "totalAmount", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "#/entities/User",
      "description": "Global users collection with roles and workspace assignment."
    },
    "workspaces/{workspaceId}": {
      "schema": "#/entities/UserWorkspace",
      "description": "User specific configurations and isolated workspace."
    },
    "workspaces/{workspaceId}/products/{productId}": {
      "schema": "#/entities/Product",
      "description": "Products managed within the workspace."
    },
    "workspaces/{workspaceId}/purchases/{purchaseId}": {
      "schema": "#/entities/Purchase",
      "description": "Purchases recorded within the workspace."
    },
    "workspaces/{workspaceId}/recipes/{recipeId}": {
      "schema": "#/entities/Recipe",
      "description": "Recipes configured within the workspace."
    },
    "workspaces/{workspaceId}/suppliers/{supplierId}": {
      "schema": "#/entities/Supplier",
      "description": "Suppliers configured within the workspace."
    },
    "workspaces/{workspaceId}/reminders/{reminderId}": {
      "schema": "#/entities/Reminder",
      "description": "Reminders configured within the workspace."
    },
    "workspaces/{workspaceId}/sales/{saleId}": {
      "schema": "#/entities/Sale",
      "description": "Sales and invoices recorded within the workspace."
    },
    "workspaces/{workspaceId}/auditLogs/{logId}": {
      "schema": "#/entities/AuditLog",
      "description": "Audit logs for actions performed within the workspace."
    }
  }
}
